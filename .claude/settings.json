{
  "attribution": {},
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(git commit *)",
      "Bash(git * main)",
      "Bash(* --version)",
      "Bash(* --help *)",
      "Read(*)",
      "WebFetch(domain:fonts.googleapis.com)",
      "WebFetch(domain:validator.schema.org)",
      "mcp__chrome-devtools__*",
      "Bash(npx tsc:*)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm *)",
      "Bash(git push *)",
      "Bash(git init *)"
    ],
    "ask": [
      "Edit(*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowUnixSockets": [],
      "allowLocalBinding": true
    }
  }
}
